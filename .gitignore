# ===================================
# ホワイトリスト形式で管理するため全てのファイルを無視する
# ===================================
/*
/.*

# ===================================
# root
# ===================================
!/.zsh
/.zsh/env.local.zsh
!/.zshrc
!/.zshenv
!/.bash
!/.claude
/.claude/settings.local.json
# shell snapshot は環境情報を含むため常に除外する
/.claude/shell-snapshots
/.bash/env.local.bash
!/.bashrc
!/README.md
!.gitignore

# ===================================
# .config
# ===================================
!/.config
/.config/*

!/.config/nvim
!/.config/mcphub
!/.config/wezterm
!/.config/starship.toml
/.config/git


# ===================================
# .bin
# ===================================
!/.bin
/.bin/*

!/.bin/install.sh
!/.bin/install-wordpress-stubs.sh
.config/nvim/lazy-lock.json
.config/nvim/intelephense.json
.config/lazygit/state.yml
.config/mcphub/servers.json
.claude

# ===================================
# .agents
# ===================================
!/.agents
/.agents/*
# Codex Skills の入口は dotfiles 側で管理し、必要なものだけを追跡する
!/.agents/skills
/.agents/skills/*
!/.agents/skills/superpowers

# ===================================
# tests
# ===================================
!/tests
!/tests/*.sh
!/tests/*.lua

# ===================================
# .codex
# ===================================
!/.codex

# Codex 配下は会話履歴、認証情報、キャッシュ、プラグインを含むため既定では全て除外する。
/.codex/*
/.codex/.*

# リポジトリで共有する Codex 向け説明書だけは追跡対象にする。
!/.codex/AGENTS.md

# superpowers は dotfiles から参照する共有資産として追跡対象にする。
!/.codex/superpowers
!/.codex/superpowers/**

# Codex の標準 Skill は共有対象にし、ユーザーがローカルに追加した Skill は除外する。
!/.codex/skills
/.codex/skills/*
/.codex/skills/.*
!/.codex/skills/.system
!/.codex/skills/.system/**
