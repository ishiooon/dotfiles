# ===================================
# ホワイトリスト形式で管理するため全てのファイルを無視する
# ===================================
/*
/.*

# ===================================
# root
# ===================================
!/.zsh
/.zsh/env.local.zsh
!/.zshrc
!/.zshenv
!/.bash
# Claude 配下はローカルの設定、履歴、作業状態を含むため、共有する説明書以外を除外する。
!/.claude/
/.claude/*
/.claude/.*
!/.claude/CLAUDE.md
/.bash/env.local.bash
!/.bashrc
!/README.md
!.gitignore

# ===================================
# .config
# ===================================
!/.config
/.config/*

!/.config/amethyst
!/.config/amethyst/**
!/.config/borders
!/.config/borders/**
!/.config/sketchybar
!/.config/sketchybar/**
!/.config/nvim
!/.config/mcphub
!/.config/wezterm
!/.config/starship.toml
/.config/git


# ===================================
# .bin
# ===================================
!/.bin
/.bin/*

!/.bin/install.sh
!/.bin/install-janky-borders.sh
!/.bin/install-sketchybar.sh
!/.bin/install-wordpress-stubs.sh
.config/nvim/lazy-lock.json
.config/nvim/intelephense.json
.config/lazygit/state.yml
.config/mcphub/servers.json

# ===================================
# .agents
# ===================================
!/.agents
/.agents/*
# Codex Skills の入口は dotfiles 側で管理し、必要なものだけを追跡する
!/.agents/skills
/.agents/skills/*
!/.agents/skills/superpowers

# ===================================
# tests
# ===================================
!/tests
!/tests/*.sh
!/tests/*.lua

# ===================================
# .codex
# ===================================
# Codex 配下は会話履歴、認証情報、キャッシュ、プラグインを含むため、共有する説明書以外を除外する。
!/.codex/
/.codex/*
/.codex/.*
!/.codex/AGENTS.md
