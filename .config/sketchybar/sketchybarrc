#!/usr/bin/env bash
set -euo pipefail

# SketchyBar から直接実行された場合と手動実行された場合の両方で同じ設定場所を使う。
CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

source "$CONFIG_DIR/colors.sh"

# reload では過去に作った item が残るため、使わなくなった中央表示を先に消す。
for stale_item in \
  music.waveform \
  music.bar.1 \
  music.bar.2 \
  music.bar.3 \
  music.bar.4 \
  music.bar.5 \
  music.bar.6 \
  space.1 \
  space.2 \
  space.3 \
  space.4 \
  space.5; do
  sketchybar --remove "$stale_item" >/dev/null 2>&1 || true
done

# 画面上部に常駐するバーとして、ウィンドウ配置側から避けられる領域を明示する。
bar_settings=(
  position=top
  height=34
  margin=8
  y_offset=8
  corner_radius=8
  blur_radius=24
  color="$BAR_COLOR"
  border_color="$BORDER_COLOR"
  border_width=1
  padding_left=8
  padding_right=8
  display=all
  sticky=on
  shadow=on
  topmost=window
)

default_settings=(
  updates=when_shown
  icon.font="SF Pro:Semibold:13.0"
  icon.color="$TEXT_COLOR"
  icon.padding_left=6
  icon.padding_right=4
  label.font="SF Pro:Medium:12.0"
  label.color="$TEXT_COLOR"
  label.padding_left=4
  label.padding_right=6
  background.drawing=off
)

sketchybar --bar "${bar_settings[@]}"
sketchybar --default "${default_settings[@]}"

# 左、中央、右の表示群を分けて読み込み、バー本体の設定を短く保つ。
source "$ITEM_DIR/left.sh"
source "$ITEM_DIR/center.sh"
source "$ITEM_DIR/right.sh"

sketchybar --update
