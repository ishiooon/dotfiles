#!/usr/bin/env bash
set -euo pipefail

# JankyBorders はこのファイルを実行し、ここで定義した見た目を borders コマンドへ渡す。
main() {
  local options=(
    # 角を丸め、macOS の標準的なウィンドウ形状と馴染ませる。
    style=round
    # 枠線をウィンドウより前面に表示し、サブモニター側で背面に隠れる状態を避ける。
    order=a
    # 細めの枠線にし、フォーカス位置を示しながら作業画面の圧迫感を抑える。
    width=3.0
    # 高解像度描画を無効にし、常駐時の描画負荷を抑える。
    hidpi=off
    # サブモニターやウィンドウ管理ツール使用時も、フォーカス中のウィンドウを安定して検出する。
    ax_focus=on
    # フォーカス中のウィンドウだけを Gruvbox Material の落ち着いた前景色で控えめに強調する。
    active_color=0xffd4be98
    # 非アクティブウィンドウの枠線は透明にし、画面全体の情報量を増やさない。
    inactive_color=0x00000000
  )

  borders "${options[@]}"
}

main "$@"
